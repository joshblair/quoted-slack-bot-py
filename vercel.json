{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "pythonVersion": "3.11" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/health",
      "schedule": "*/5 * * * *"
    }
  ]
}
