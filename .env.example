# Copy this file to .env and fill in the values.
# The Python bot shares the same MongoDB instance as the TypeScript app.
# The Slack credentials are the same too — both bots use the same Slack app.

SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Same MongoDB URI as the TypeScript app
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# Public URL of THIS Python deployment (used to build the /connect link)
APP_BASE_URL=https://your-python-bot.vercel.app

# Base URL for request links shown in Slack messages
DEMO_REQUEST_BASE_URL=https://demo.qwoted.com/request

# Session cookie name — must match the TypeScript app if sharing sessions
SESSION_COOKIE_NAME=qwoted_session
